{
  "baseUrl": "https://www.instagram.com/explore/",
  "runMinutes": 60,
  "headless": false,
  "profileDir": "./profiles/instagram",
  "likeProbability": 0.22,
  "commentProbability": 0.08,
  "minWaitMs": 25000,
  "maxWaitMs": 60000,
  "login": {
    "mode": "cookie_bootstrap",
    "cookieFilePath": "default.cookies.json",
    "waitForManualConfirm": false,
    "exportCookiesOnExit": true,
    "exportCookieFilePath": "./profiles/instagram/cookies.json"
  },
  "isolation": {
    "enabled": false,
    "fingerprintPreset": "desktop_chrome_default",
    "behaviorPreset": "human_browse_lowfreq",
    "locale": "en-US",
    "timezoneId": "America/Los_Angeles",
    "userAgent": "",
    "viewportWidth": 1366,
    "viewportHeight": 768
  }
}
