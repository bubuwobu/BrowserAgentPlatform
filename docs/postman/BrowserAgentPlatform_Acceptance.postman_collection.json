{
  "info": {
    "name": "BrowserAgentPlatform Acceptance",
    "description": "用于自动化 + 隔离闭环验收。包含登录、Profile 隔离检查、闭环 start/execute、Run 查询、Observability 查询。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:12126" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "Admin@123456" },
    { "key": "token", "value": "" },
    { "key": "profileId", "value": "1" },
    { "key": "agentKey", "value": "validator-local" },
    { "key": "taskId", "value": "" },
    { "key": "runId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "1. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "2. List Profiles",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/profiles",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles"]
        }
      }
    },
    {
      "name": "3. Create Profile (Isolation Fields)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "if (json && json.id) { pm.collectionVariables.set('profileId', String(json.id)); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"acceptance-profile-1\",\n  \"ownerAgentId\": null,\n  \"proxyId\": null,\n  \"fingerprintTemplateId\": null,\n  \"localProfilePath\": \"/tmp/bap/profile-1\",\n  \"storageRootPath\": \"/tmp/bap/storage-1\",\n  \"downloadRootPath\": \"/tmp/bap/download-1\",\n  \"startupArgsJson\": \"[]\",\n  \"isolationPolicyJson\": \"{\\\"timezone\\\":\\\"Asia/Shanghai\\\",\\\"locale\\\":\\\"zh-CN\\\"}\",\n  \"isolationLevel\": \"strict\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/profiles",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles"]
        }
      }
    },
    {
      "name": "4. Profile Isolation Check",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/{{profileId}}/isolation-check",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "{{profileId}}", "isolation-check"]
        }
      }
    },
    {
      "name": "5. Closed Loop Start",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "if (json && json.taskId) { pm.collectionVariables.set('taskId', String(json.taskId)); }",
              "if (json && json.runId) { pm.collectionVariables.set('runId', String(json.runId)); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profileId\": {{profileId}},\n  \"agentKey\": \"{{agentKey}}\",\n  \"taskName\": \"acceptance-closed-loop\",\n  \"payloadJson\": \"{\\\"mode\\\":\\\"closed-loop-validation\\\"}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/validation/closed-loop/start",
          "host": ["{{baseUrl}}"],
          "path": ["api", "validation", "closed-loop", "start"]
        }
      }
    },
    {
      "name": "6. Closed Loop Execute",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"runId\": {{runId}},\n  \"agentKey\": \"{{agentKey}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/validation/closed-loop/execute",
          "host": ["{{baseUrl}}"],
          "path": ["api", "validation", "closed-loop", "execute"]
        }
      }
    },
    {
      "name": "7. Run Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/tasks/runs/{{runId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks", "runs", "{{runId}}"]
        }
      }
    },
    {
      "name": "8. Run Isolation Report",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/tasks/runs/{{runId}}/isolation-report",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks", "runs", "{{runId}}", "isolation-report"]
        }
      }
    },
    {
      "name": "9. Live Summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/live/summary",
          "host": ["{{baseUrl}}"],
          "path": ["api", "live", "summary"]
        }
      }
    },
    {
      "name": "10. Observability Overview",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/observability/overview",
          "host": ["{{baseUrl}}"],
          "path": ["api", "observability", "overview"]
        }
      }
    },
    {
      "name": "11. Audit Events",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/observability/audit-events?take=200",
          "host": ["{{baseUrl}}"],
          "path": ["api", "observability", "audit-events"],
          "query": [
            { "key": "take", "value": "200" }
          ]
        }
      }
    }
  ]
}
